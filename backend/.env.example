# Backend env example (Render/local)
MONGODB_ATLAS_URI=mongodb+srv://DB_USER:DB_PASSWORD@cluster0.xxxxx.mongodb.net/molgen?retryWrites=true&w=majority
MONGO_DB_NAME=molgen
MONGO_COLLECTION_NAME=generated_molecules
MONGO_ENABLED=true
MONGO_SERVER_SELECTION_TIMEOUT_MS=10000

# CORS for local + deployed frontend
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:3001,http://127.0.0.1:3001,https://your-frontend.vercel.app
# Optional: allow all Vercel preview domains
ALLOWED_ORIGIN_REGEX=https://.*\.vercel\.app

# Optional: silence Hugging Face warnings (Windows symlinks; unauthenticated rate-limit)
# HF_HUB_DISABLE_SYMLINKS_WARNING=1
# HF_TOKEN=your_huggingface_token

# Optional model env
GENERATOR_BACKEND=learned
LEARNED_MODEL_NAME=chandar-lab/NovoMolGen_32M_SMILES_BPE
LEARNED_MODEL_REVISION=hf-checkpoint
LEARNED_MODEL_BATCH_SIZE=16
LEARNED_MODEL_MAX_NEW_TOKENS=96
